---
import { withBase } from "../lib/paths.ts";
import { soulListPath, totalPages } from "../lib/pagination.ts";

interface Props {
  page: number;
  total: number;
  perPage: number;
  type?: string;
}

const { page, total, perPage, type } = Astro.props;
const base = import.meta.env.BASE_URL;
const pages = totalPages(total, perPage);
const prevPage = page > 1 ? page - 1 : null;
const nextPage = page < pages ? page + 1 : null;
---

<nav class="pagination" aria-label="Records pagination">
  {
    prevPage !== null ? (
      <a href={withBase(soulListPath(prevPage, type), base)}>← Previous</a>
    ) : (
      <span class="pagination__status">← Previous</span>
    )
  }
  <span class="pagination__status">
    Page {page} of {pages}
  </span>
  {
    nextPage !== null ? (
      <a href={withBase(soulListPath(nextPage, type), base)}>Next →</a>
    ) : (
      <span class="pagination__status">Next →</span>
    )
  }
</nav>
