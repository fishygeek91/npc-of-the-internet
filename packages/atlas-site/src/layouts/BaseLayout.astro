---
import "../styles/global.css";
import { withBase } from "../lib/paths.ts";

interface Props {
  title: string;
  description?: string;
  current?: "home" | "journey" | "journals" | "soul";
}

const { title, description, current } = Astro.props;
const base = import.meta.env.BASE_URL;
const pageTitle = title === "Atlas" ? "Atlas — NPC of the Internet" : `${title} — Atlas`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description !== undefined && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Source+Sans+3:wght@400;600&family=Syne:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-brand" href={withBase("/", base)}>Atlas</a>
        <nav class="site-nav" aria-label="Primary">
          <a href={withBase("/", base)} aria-current={current === "home" ? "page" : undefined}>Home</a>
          <a href={withBase("/journey/", base)} aria-current={current === "journey" ? "page" : undefined}>Journey</a>
          <a href={withBase("/journals/", base)} aria-current={current === "journals" ? "page" : undefined}>Journals</a>
          <a href={withBase("/soul/", base)} aria-current={current === "soul" ? "page" : undefined}>Soul</a>
        </nav>
      </div>
    </header>
    <main class="site-main">
      <slot />
    </main>
  </body>
</html>
