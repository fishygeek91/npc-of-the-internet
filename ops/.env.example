# Ghost compose — names-only placeholders. Copy to ops/.env and replace before deploy.
# Validate: docker compose --env-file ops/.env.example -f ops/compose.ghost.yml config

NPC_IMAGE_TAG=latest

# Host paths (never commit real key files or rclone secrets)
SOUL_KEY_HOST_PATH=/tmp/npc-ghost/keys/soul.key
DOOR_KEY_HOST_PATH=/tmp/npc-ghost/keys/door.key
RCLONE_CONFIG_HOST_PATH=/tmp/npc-ghost/rclone

# Runtime / Brain (ops/SECRETS.md)
ANTHROPIC_API_KEY=replace-me
NPC_BRAIN_MODEL=claude-sonnet-4-20250514
NPC_BRAIN_MAX_TOKENS=1024
NPC_BRAIN_TIMEOUT_MS=60000

# door-discord (packages/door-discord/src/config.ts)
# CURRENT_DOOR_ID for runtime is derived in compose as discord:${DISCORD_GUILD_ID} — no need to set it in .env unless overriding.
DISCORD_BOT_TOKEN=replace-me
DISCORD_GUILD_ID=1000000000000000001
DISCORD_CHANNEL_ID=1000000000000000002
DISCORD_OPERATOR_IDS=1000000000000000004
DISCORD_REVIEW_TIMEOUT_MS=300000
DISCORD_REVIEW_CHANNEL_ID=
DISCORD_USER_RATE_PER_MIN=20
DISCORD_USER_BURST=5
DISCORD_CHANNEL_RATE_PER_MIN=60
DISCORD_CHANNEL_BURST=15
DISCORD_COMMUNITY_NAME=Discord Door
DISCORD_COMMUNITY_DESCRIPTION=A Discord channel hosting the Wanderer.
# TEST-ONLY fill-byte soul public key (see packages/atlas/test/helpers/fixed-keys.ts)
SOUL_PUBLIC_KEY=6kpsY-KcUgq-9VB7Ey7F-ZVHdq6-vnuSQh7qaRRG0iw

# atlas-api (packages/atlas/src/config.ts)
ATLAS_DOOR_PUBKEYS=E5j2LG0aRXxRumpLXz29L2n8qTIWIY3ImX5Ba9F9k8o

# backup sidecar (ops/scripts/backup-watch.sh)
BACKUP_RCLONE_REMOTE=ghost-remote:npc/soulchain
BACKUP_DEBOUNCE_SEC=5
BACKUP_INTERVAL_SEC=300
